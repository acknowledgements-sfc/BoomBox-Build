{
  "buildCommand": null,
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/mcp.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/mcp",
      "destination": "/api/mcp"
    },
    {
      "source": "/",
      "destination": "/web/index.html"
    },
    {
      "source": "/system-map",
      "destination": "/docs/park-jukebox-system-map.html"
    }
  ]
}
