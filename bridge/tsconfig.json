{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "rootDir": "..",
    "outDir": "../dist",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "../api/**/*.ts"]
}
